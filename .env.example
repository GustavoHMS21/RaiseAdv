# =============================================================================
# RaiseAdv — Variáveis de Ambiente
# =============================================================================
# NUNCA commitar .env.local com valores reais no git.
# Copie este arquivo: cp .env.example .env.local
# =============================================================================

# --- Supabase (obrigatório) ---
# Pegar em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: APENAS server-side (webhooks, crons). NUNCA expor ao client.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- DataJud / CNJ (para busca de andamentos) ---
# Chave pública do CNJ — pegar em datajud-wiki.cnj.jus.br
DATAJUD_API_KEY=

# --- Resend (para emails de lembrete de prazo) ---
RESEND_API_KEY=

# --- Stripe (futuro, billing) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
